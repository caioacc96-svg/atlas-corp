{
  "name": "atlas-corp-desktop",
  "version": "2.1.0",
  "private": true,
  "description": "Atlas Corp Desktop v2.1.0 - Chat-first stabilized",
  "main": "dist-electron/main/main.js",
  "author": "OpenAI for Dr. Caio Augusto",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:backend\" \"npm:dev:app\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json --watch",
    "dev:backend": "tsx watch backend/src/server.ts",
    "dev:app": "wait-on tcp:5173 dist-electron/main/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electronmon .",
    "build": "npm run build:electron && npm run build:renderer && npm run build:backend",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "build:backend": "tsc -p tsconfig.backend.json",
    "dist": "tsc -p tsconfig.electron.json && vite build && tsc -p tsconfig.backend.json && electron-builder --win nsis",
    "start:backend": "node dist-backend/backend/src/server.js",
    "preview": "vite preview",
    "doctor:win": "powershell -ExecutionPolicy Bypass -File ./scripts/atlas-win-doctor.ps1",
    "build:win": "powershell -ExecutionPolicy Bypass -File ./scripts/atlas-win-build.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:report": "npm.cmd audit || true",
    "audit:deps": "npm.cmd ls electron electron-builder tar @electron/rebuild app-builder-lib || true"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.2.1",
    "framer-motion": "^11.3.19",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.2",
    "pino": "^9.5.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.1"
  }
}
